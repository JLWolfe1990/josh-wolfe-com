{
  "$schema": "/opt/homebrew/lib/node_modules/wrangler/config-schema.json",
  "name": "josh-wolfe-com",
  "main": "worker.js",
  "account_id": "55c84df414e8212cfcf7b7deef3e27ea",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "josh-wolfe.com/*",
      "zone_name": "josh-wolfe.com"
    },
    {
      "pattern": "www.josh-wolfe.com/*",
      "zone_name": "josh-wolfe.com"
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  }
}
